# ======================================================================
# NeuroQuant Backend - Environment Configuration
# ======================================================================

# --- Application ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
PROJECT_NAME=NeuroQuant
API_V1_PREFIX=/api/v1

# --- Databases ---
DATABASE_URL=sqlite+aiosqlite:///./dev.db
SYNC_DATABASE_URL=sqlite:///./dev.db
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# --- Redis & Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
REDIS_CACHE_TTL=300

# --- JWT (RS256) Security ---
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption & Security ---
FIELD_ENCRYPTION_KEY=uje86foHI6RC8QSlIR_iLukXMRyrwJSyntb6n9fZgRQ=
RATE_LIMIT_ENABLED=false

# --- Upstox Broker Integration ---
UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_API_SECRET=your_upstox_api_secret
UPSTOX_REDIRECT_URI=http://localhost:8000/api/v1/auth/upstox/callback
UPSTOX_MAX_ORDER_VALUE=10000.0

# --- Safety Flag ---
LIVE_EXECUTION_CONFIRMED=OFF
