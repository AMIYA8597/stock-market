# ══════════════════════════════════════════════════════════════════════
# NEUROQUANT — Environment Configuration  (47 required variables)
# NIT Rourkela M.Tech Thesis — Institutional AI Trading Platform
#
# SETUP:
#   bash scripts/setup.sh     → auto-copies this to .env and injects
#                               generated Fernet key
#   pwsh scripts/setup.ps1    → same, but Windows-native
#
# SECURITY:
#   - NEVER commit .env to git  (pre-commit hook enforces this)
#   - NEVER commit keys/ directory
#   - Generate JWT keys with: openssl genrsa -out keys/private.pem 2048
#   - Generate Fernet key with setup script (done automatically)
# ══════════════════════════════════════════════════════════════════════

# ─── Database (PostgreSQL 16 + TimescaleDB 2.14) ───────────────────────
# Async URL used by FastAPI / SQLAlchemy 2.0 (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://neuroquant:changeme@localhost:5432/neuroquant_db
# Sync URL used by Alembic migrations
SYNC_DATABASE_URL=postgresql://neuroquant:changeme@localhost:5432/neuroquant_db
# Postgres Docker credentials (used by docker-compose)
POSTGRES_USER=neuroquant
POSTGRES_PASSWORD=changeme
POSTGRES_DB=neuroquant_db
# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ─── Redis 7.2 ──────────────────────────────────────────────────────────
# DB 0: general cache + rate-limit counters
REDIS_URL=redis://localhost:6379/0
# DB 1: Celery task broker
CELERY_BROKER_URL=redis://localhost:6379/1
# DB 2: Celery result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Default cache TTL in seconds (5 minutes)
REDIS_CACHE_TTL=300

# ─── JWT (RS256) — generate key pair with setup script ─────────────────
# NEVER use HS256 in production — always RS256 for a financial platform
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Field-Level Encryption (AES-256 via Fernet) ───────────────────────
# Generated automatically by setup script — DO NOT COMMIT this value
# Regenerate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=REPLACE_ME_WITH_FERNET_KEY_FROM_SETUP_SCRIPT

# ─── TOTP (RFC 6238) Two-Factor Authentication ──────────────────────────
TOTP_ISSUER=NeuroQuant
TOTP_DIGITS=6

# ─── Email (SendGrid) ───────────────────────────────────────────────────
SENDGRID_API_KEY=SG.REPLACE_WITH_REAL_SENDGRID_KEY
FROM_EMAIL=noreply@neuroquant.app

# ─── Market Data APIs ───────────────────────────────────────────────────
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=REPLACE_ME
# Finnhub: https://finnhub.io/dashboard
FINNHUB_API_KEY=REPLACE_ME
# NewsAPI: https://newsapi.org/account
NEWS_API_KEY=REPLACE_ME
# FRED (Federal Reserve Economic Data): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=REPLACE_ME
# Polygon.io (institutional-grade tick data): https://polygon.io/dashboard
POLYGON_API_KEY=REPLACE_ME

# ─── OAuth2 Social Login (PKCE flow via NextAuth.js v5) ─────────────────
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME
# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=REPLACE_ME
GITHUB_CLIENT_SECRET=REPLACE_ME
# NextAuth.js — must be 32+ characters
NEXTAUTH_SECRET=REPLACE_ME_WITH_MINIMUM_32_RANDOM_CHARS_HERE
NEXTAUTH_URL=http://localhost:3000

# ─── ML / MLflow ────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001
MODEL_ARTIFACTS_PATH=./ml/artifacts
# HuggingFace token for FinBERT / FinGPT model downloads
HUGGINGFACE_TOKEN=hf_REPLACE_ME

# ─── MinIO (S3-compatible object storage for ML artifacts) ──────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret_change_me
MINIO_BUCKET_MODELS=ml-models
MINIO_SECURE=false

# ─── Monitoring & Tracing ────────────────────────────────────────────────
# Prometheus multiprocess directory (must exist and be writable)
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_neuroquant
# Jaeger agent (distributed tracing)
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# ─── Application Settings ────────────────────────────────────────────────
ENVIRONMENT=development
# IMPORTANT: must be false in production
DEBUG=false
LOG_LEVEL=INFO
# Comma-separated allowed origins for CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]
# Max concurrent WebSocket connections per authenticated user
MAX_CONNECTIONS_PER_USER=10
# Global rate limit — requests per minute per IP
RATE_LIMIT_PER_MINUTE=1000

# ─── Meilisearch (instant symbol search) ────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
# Generate a secure master key: python -c "import secrets; print(secrets.token_urlsafe(40))"
MEILISEARCH_MASTER_KEY=REPLACE_ME_WITH_SECURE_RANDOM_KEY

# ─── LLM (Multi-Agent Research System) ──────────────────────────────────
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME
# gpt-4o-mini for cost-efficiency; switch to gpt-4o for higher accuracy
LLM_MODEL=gpt-4o-mini

# ─── Frontend (Next.js public env vars) ─────────────────────────────────
# These are exposed to the browser — do NOT put secrets here
NEXT_PUBLIC_API_URL=http://localhost:80/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:80/ws
NEXT_PUBLIC_MEILISEARCH_URL=http://localhost:7700
# Public (read-only) Meilisearch search key — different from master key
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=REPLACE_ME_PUBLIC_SEARCH_KEY
