{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".env.local",
    ".env.example",
    "tsconfig.json"
  ],
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WS_URL",
    "NEXTAUTH_URL",
    "NEXTAUTH_SECRET",
    "DATABASE_URL",
    "REDIS_URL",
    "JWT_PRIVATE_KEY_PATH",
    "JWT_PUBLIC_KEY_PATH",
    "ENVIRONMENT"
  ],
  "pipeline": {
    "build": {
      "dependsOn": ["^build", "^type-check"],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ],
      "env": [
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_WS_URL",
        "NEXTAUTH_URL"
      ]
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "type-check": {
      "outputs": [],
      "cache": true
    },
    "test": {
      "outputs": ["coverage/**"],
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URL",
        "REDIS_URL"
      ],
      "cache": true
    },
    "test:coverage": {
      "outputs": ["coverage/**"],
      "dependsOn": ["^build"],
      "cache": true
    },
    "test:e2e": {
      "outputs": ["playwright-report/**"],
      "dependsOn": ["build"],
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}

