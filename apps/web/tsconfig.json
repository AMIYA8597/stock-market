{
  "extends": "@neuroquant/config/tsconfig.nextjs.json",
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": ["./src/*"],
      "@neuroquant/types": ["../../packages/types/src/index"],
      "@neuroquant/ui": ["../../packages/ui/src/index"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "**/*.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
